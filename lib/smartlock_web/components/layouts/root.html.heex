<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Smartlock" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body class="bg-gray-50">
  <% current_path = @conn.request_path %>

    <header class="bg-white shadow-sm px-6 py-3 flex items-center justify-between">
      <!-- Left: App name -->
      <div class="text-xl font-bold text-gray-800">
        <.link navigate={~p"/"} class="text-xl font-bold text-gray-800">
          SmartLock Manager
        </.link>
      </div>

      <!-- Right: User / notifications -->
      <div class="flex items-center gap-4">
        <!-- Notifications -->
        <button class="relative p-2 rounded hover:bg-gray-100">
          <.icon name="hero-bell" class="w-5 h-5 text-gray-600"/>
          <span class="absolute -top-0.2 -right-0.1 w-2 h-2 bg-red-500
          rounded-full"></span>
        </button>

        <!-- User -->
        <div class="relative">
          <!-- User button -->
          <button
            phx-click={JS.toggle(to: "#user-menu-dropdown", in: "transition ease-out duration-150 transform opacity-0 scale-95", out: "transition ease-in duration-100 transform opacity-100 scale-100")}
            class="flex items-center gap-2 px-2 py-1 rounded hover:bg-gray-100 focus:outline-none"
          >
            <span class="text-gray-700 font-medium">Brendan Lentz</span>
            <.icon name="hero-user-circle" class="w-6 h-6 text-gray-500"/>
          </button>

          <!-- Dropdown menu -->
          <div
            id="user-menu-dropdown"
            class="hidden absolute right-0 mt-2 w-56 bg-white border rounded shadow-lg z-50 origin-top-right"
            phx-click-away={JS.hide(to: "#user-menu-dropdown")}
            phx-window-keydown={JS.hide(to: "#user-menu-dropdown")}
            phx-key="escape"
            phx-update="ignore"
          >
            <!-- External links -->
            <.link navigate="https://github.com/blentz100" target="_blank"
              class="flex items-center gap-2 px-4 py-2 text-gray-700 hover:bg-gray-100">
              <.icon name="hero-mark-github" class="w-5 h-5 text-gray-400"/>
              GitHub
            </.link>

            <.link navigate="https://linkedin.com/in/brendanlentz" target="_blank"
              class="flex items-center gap-2 px-4 py-2 text-gray-700 hover:bg-gray-100">
              <.icon name="hero-linkedin" class="w-5 h-5 text-gray-400"/>
              LinkedIn
            </.link>

            <.link navigate="https://brendanlentz.com" target="_blank"
              class="flex items-center gap-2 px-4 py-2 text-gray-700 hover:bg-gray-100">
              <.icon name="hero-globe-alt" class="w-5 h-5 text-gray-400"/>
              Personal Website
            </.link>

            <hr class="my-1 border-gray-200"/>

            <!-- Fun demo actions -->
            <.link phx-click="random_lock_action"
              class="flex items-center gap-2 px-4 py-2 text-gray-700 hover:bg-gray-100 cursor-pointer">
              <.icon name="hero-shuffle" class="w-5 h-5 text-gray-400"/>
              Random Lock Action
            </.link>

            <.link phx-click="reset_demo"
              class="flex items-center gap-2 px-4 py-2 text-gray-700 hover:bg-gray-100 cursor-pointer">
              <.icon name="hero-refresh" class="w-5 h-5 text-gray-400"/>
              Reset Demo
            </.link>
          </div>
        </div>
      </div>
    </header>


  <div class="flex flex-1 h-[calc(100vh-64px)]">
    <aside class="w-45 bg-white border-r flex flex-col">

      <div class="flex-1 overflow-y-auto px-4 py-4 text-sm">

        <!-- Community -->
        <div class="text-gray-400 uppercase text-xs mb-2">
          Community
        </div>

        <div class="flex items-center gap-2 ml-2 mb-4 text-gray-800">
          <.icon name="hero-building-office-2" class="w-4 h-4"/>
          Garden View
        </div>

        <!-- Favorites -->
        <div class="text-gray-400 uppercase text-xs mb-2">
          Favorites
        </div>

        <div class="flex items-center gap-2 ml-2 mb-6 text-gray-400">
          <.icon name="hero-star" class="w-4 h-4"/>
          No Favorites Yet
        </div>

        <!-- Management -->
        <div class="text-gray-400 uppercase text-xs mb-2">
          Management
        </div>

        <ul class="space-y-2 mb-6 ml-2">

          <li class="flex items-center gap-2 text-gray-400">
            <.icon name="hero-home" class="w-4 h-4"/>
            Overview
          </li>

          <li class="flex items-center gap-2 text-gray-400">
            <.icon name="hero-building-office" class="w-4 h-4"/>
            Units
          </li>

          <li>
            <.link
              navigate={~p"/"}
              class={[
                "flex items-center gap-2",
                current_path == "/" && "text-blue-600 font-medium",
                current_path != "/" && "text-gray-400"
              ]}
            >
              <.icon name="hero-lock-closed" class="w-4 h-4"/>
              Access
            </.link>
          </li>

          <li class="flex items-center gap-2 text-gray-400">
            <.icon name="hero-clock" class="w-4 h-4"/>
            Activity
          </li>

          <li class="flex items-center gap-2 text-gray-400">
            <.icon name="hero-document-text" class="w-4 h-4"/>
            Leasing
          </li>

          <li class="flex items-center gap-2 text-gray-400">
            <.icon name="hero-user-group" class="w-4 h-4"/>
            Guests
          </li>

          <li class="flex items-center gap-2 text-gray-400">
            <.icon name="hero-wrench-screwdriver" class="w-4 h-4"/>
            Maintenance
          </li>

          <li class="flex items-center gap-2 text-gray-400">
            <.icon name="hero-map" class="w-4 h-4"/>
            Tours
          </li>

          <li class="flex items-center gap-2 text-gray-400">
            <.icon name="hero-truck" class="w-4 h-4"/>
            Parking
          </li>

        </ul>

        <!-- Admin -->
        <div class="text-gray-400 uppercase text-xs mb-2">
          Admin
        </div>

        <ul class="space-y-2 ml-2">

          <li class="flex items-center gap-2 text-gray-400">
            <.icon name="hero-users" class="w-4 h-4"/>
            Users
          </li>

          <li class="flex items-center gap-2 text-gray-400">
            <.icon name="hero-chart-bar" class="w-4 h-4"/>
            Reports
          </li>

          <li class="flex items-center gap-2 text-gray-400">
            <.icon name="hero-cog-6-tooth" class="w-4 h-4"/>
            Settings
          </li>

          <li class="flex items-center gap-2 text-gray-400">
            <.icon name="hero-question-mark-circle" class="w-4 h-4"/>
            Help
          </li>

        </ul>

      </div>

    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto p-8">
      <%= @inner_content %>
    </main>

  </div>

  </body>
</html>
